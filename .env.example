# Gmail credentials (generate an App Password at https://myaccount.google.com/apppasswords)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where to deliver alerts
RECIPIENT_EMAIL=you@gmail.com

# How often to poll each source (minutes)
POLL_INTERVAL_MINUTES=20

# Path to the SQLite dedup database inside the container
DB_PATH=data/contracts.db
